{
  "name": "meshfleet",
  "version": "0.14.0",
  "description": "Auditable multi-agent coordination for OpenCode — parallel agent fleets with P2P messaging, witnessed receipts, and quorum ratification. Who saw this, who approved it, prove it.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "meshfleet": "dist/index.js",
    "agent-mesh": "dist/bin/inspect.js",
    "agent-mesh-dashboard": "dist/bin/dashboard.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENT-MESH-SPEC.md",
    "SPEC-P2P.md",
    "SPEC-COUNCILS.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "inspect": "node dist/bin/inspect.js",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "release:pack": "npm pack",
    "release:verify": "npm run build && npm test && npm pack --dry-run",
    "release:publish": "npm run release:verify && npm publish"
  },
  "keywords": [
    "mcp",
    "opencode",
    "agent",
    "orchestration",
    "swarm",
    "fleet",
    "p2p",
    "peer-to-peer",
    "model-context-protocol",
    "audit",
    "receipts",
    "quorum",
    "multi-agent"
  ],
  "license": "MIT",
  "homepage": "https://meshfleet.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnmwhitman/agent-mesh.git"
  },
  "bugs": {
    "url": "https://github.com/johnmwhitman/agent-mesh/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
